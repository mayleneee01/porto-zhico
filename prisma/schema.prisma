// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_POSTGRES_URL_NON_POOLING")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String?
  techStack   String
  demoUrl     String?
  githubUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Certification {
  id        String   @id @default(cuid())
  name      String
  issuer    String
  date      String
  image     String?
  url       String?
  category  String   @default("certification")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  position    String
  company     String
  date        String
  description String
  category    String   @default("professional")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
